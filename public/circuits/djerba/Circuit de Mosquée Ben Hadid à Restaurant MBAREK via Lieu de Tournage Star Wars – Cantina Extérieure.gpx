  <wpt lat="33.721583" lon="10.774333">
    <name>Mosquée Ben Hadid</name>
    <desc>Ancienne mosquée ibadite wahbite rénovée récemment.</desc>
    <link href="http://palaisbenayed.com/wp-content/uploads/2021/03/r%C3%A9pertoire-des-mosqu%C3%A9es-de-Djerba.pdf">
      <text>Lien vers le site</text>
    </link>
  </wpt>
  <wpt lat="33.71872346897096" lon="10.770022859969572">
    <name>Mosquée Briguen</name>
  </wpt>
  <wpt lat="33.71523" lon="10.75989">
    <name>Mosquée Boubarnouss</name>
    <desc>Ancienne mosquée ibadite wahbite rénovée récemment.</desc>
  </wpt>
  <wpt lat="33.721111" lon="10.756444">
    <name>Mosquée Ben Abbas</name>
    <desc>Mosquée ibadite wahbite construite en 1046 de l’hégire, soit en 1637 de notre ère</desc>
    <link href="https://arachne.dainst.org/entity/7043417?fl=20&amp;q=connectedEntities:7343375&amp;resultIndex=1">
      <text>Lien vers le site</text>
    </link>
  </wpt>
  <wpt lat="33.725446" lon="10.751489">
    <name>Mosquée El Fguira</name>
    <desc>Mosquée ibadite wahbite construite en 1117 de l’hégire, soit 1705 de notre ère</desc>
  </wpt>
  <wpt lat="33.72404" lon="10.750008">
    <name>Lieu de Tournage Star Wars – Cantina Extérieure</name>
    <desc>Un des lieux de tournage de Star Wars</desc>
  </wpt>
  <wpt lat="33.724257" lon="10.748454">
    <name>Mosquée El Hawanit</name>
    <desc>Ancienne mosquée ibadite wahbite dont la construction remonte à 1040/1050 de l&apos;hégire, soit au 17ème siècle de notre ère (1630/1640) avant d&apos;être agandie au 19ème siècle</desc>
  </wpt>
  <wpt lat="33.72475" lon="10.747667">
    <name>Mosquée Neuve</name>
    <desc>Mosquée malékite construite au 20ème siècle</desc>
  </wpt>
  <wpt lat="33.71986" lon="10.74423">
    <name>Fort Borj Ajim</name>
    <desc>L&apos;accès est restreint et demande des autorisations</desc>
